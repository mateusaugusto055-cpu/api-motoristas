extends layouts/main.pug

block content
    .profile-container
        h1 👤 Meu Perfil
        
        if error
            .alert.alert-error= error
        
        if success
            .alert.alert-success= success
        
        .profile-info
            .profile-avatar
                if user.tipo === 'motorista'
                    img(src="https://cdn-icons-png.flaticon.com/512/1998/1998627.png", alt="Motorista")
                else if user.tipo === 'passageiro'
                    img(src="https://cdn-icons-png.flaticon.com/512/1998/1998626.png", alt="Passageiro")
                else
                    img(src="https://cdn-icons-png.flaticon.com/512/1998/1998625.png", alt="Admin")
            
            .profile-details
                p
                    strong Nome: 
                    span= user.nome
                p
                    strong Email: 
                    span= user.email
                
                //- ✅ MOSTRAR TELEFONE DO PERFIL CORRETO
                if user.tipo === 'motorista' && driver
                    p
                        strong Telefone: 
                        span= driver.telefone || 'Não informado'
                else if user.tipo === 'passageiro' && passenger
                    p
                        strong Telefone: 
                        span= passenger.telefone || 'Não informado'
                else
                    p
                        strong Telefone: 
                        span= user.telefone || 'Não informado'
                
                p
                    strong Login: 
                    span= user.login
                p
                    strong Tipo: 
                    span= user.tipo
                
                if user.tipo === 'motorista' && driver
                    p
                        strong Modelo do Carro: 
                        span= driver.modelo || 'Não informado'
                    p
                        strong Ano do Carro: 
                        span= driver.ano || 'Não informado'
                    p
                        strong Placa: 
                        span= driver.placa || 'Não informado'
                    p
                        strong Código da Habilitação (CNH): 
                        span= driver.cnh || 'Não informado'
                
                if user.tipo === 'admin'
                    p
                        strong 👑 Administrador - Acesso total ao sistema
                
                p
                    strong Status: 
                    if user.status === 'ativo'
                        span.status-active ✅ Ativo
                    else
                        span.status-inactive ⛔ Suspenso
        
        .profile-actions
            a.btn.btn-secondary(href="/profile/edit") Editar Perfil
            button.btn.btn-danger(onclick="confirmDelete()") Deletar Conta

block scripts
    script.
        function confirmDelete() {
            if (confirm('Tem certeza que deseja deletar sua conta? Esta ação é irreversível!')) {
                window.location.href = '/profile/delete';
            }
        }