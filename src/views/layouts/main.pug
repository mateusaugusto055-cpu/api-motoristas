doctype html
html(lang="pt-BR")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title= title || 'API Motoristas'
        link(rel="stylesheet", href="/css/style.css")
    body
        header
            nav
                .container
                    h1.logo 🚗 API Motoristas
                    ul.nav-links
                        if user
                            li: a(href="/profile") Meu Perfil
                            li: a(href="/logout") Sair
                        else
                            li: a(href="/login") Login
                            li: a(href="/register") Cadastrar
                        if user && user.role === 'admin'
                            li: a(href="/admin/users") Admin
                        li: a(href="/drivers-view") Motoristas
                        li: a(href="/passengers-view") Passageiros

        main.container
            block content

        footer
            .container
                p &copy; 2026 API Motoristas - Node.js, Express, MongoDB