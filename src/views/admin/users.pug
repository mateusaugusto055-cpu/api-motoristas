extends ../layouts/main.pug

block content
    h1 👑 Painel Administrativo - Usuários
    
    if success
        .alert.alert-success= success

    if error
        .alert.alert-error= error
    
    .admin-tabs
        button.tab-btn.active(onclick="showTab('motoristas')") Motoristas
        button.tab-btn(onclick="showTab('passageiros')") Passageiros
    
    #motoristas.tab-content.active
        h2 🚗 Motoristas
        if motoristas && motoristas.length > 0
            table.admin-table
                thead
                    tr
                        th Nome
                        th Email
                        th Modelo
                        th Placa
                        th Status
                        th Ações
                tbody
                    each driver in motoristas
                        tr
                            td= driver.nome
                            td= driver.email
                            td= driver.modelo || '-'
                            td= driver.placa || '-'
                            td
                                if driver.status === 'ativo'
                                    span.status-active ✅ Ativo
                                else
                                    span.status-inactive ⛔ Inativo
                            td
                                button.btn.btn-danger(onclick=`confirmarExclusao('motorista', '${driver._id}', '${driver.nome}')`) 🗑️ Excluir
        else
            p Nenhum motorista cadastrado.
    
    #passageiros.tab-content
        h2 👤 Passageiros
        if passageiros && passageiros.length > 0
            table.admin-table
                thead
                    tr
                        th Nome
                        th Email
                        th Telefone
                        th Status
                        th Ações
                tbody
                    each passenger in passageiros
                        tr
                            td= passenger.nome
                            td= passenger.email
                            td= passenger.telefone || '-'
                            td
                                if passenger.status === 'ativo'
                                    span.status-active ✅ Ativo
                                else
                                    span.status-inactive ⛔ Inativo
                            td
                                button.btn.btn-danger(onclick=`confirmarExclusao('passageiro', '${passenger._id}', '${passenger.nome}')`) 🗑️ Excluir
        else
            p Nenhum passageiro cadastrado.

block scripts
    script.
        function showTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            document.getElementById(tabId).classList.add('active');
            document.querySelector(`.tab-btn[onclick="showTab('${tabId}')"]`).classList.add('active');
        }

        function confirmarExclusao(tipo, id, nome) {
            const mensagem = tipo === 'motorista' 
                ? `Tem certeza que deseja excluir o motorista "${nome}"?` 
                : `Tem certeza que deseja excluir o passageiro "${nome}"?`;
            
            if (confirm(mensagem)) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/admin/delete/${tipo}/${id}`;
                document.body.appendChild(form);
                form.submit();
            }
        }